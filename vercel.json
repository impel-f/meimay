{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "dest": "/marketing.html",
      "check": true
    },
    {
      "src": "/app(?:/.*)?",
      "headers": {
        "Location": "/"
      },
      "status": 307
    },
    {
      "src": "/api/gemini",
      "dest": "/api/gemini.js",
      "check": true
    },
    {
      "src": "/api/kanji-cache",
      "dest": "/api/kanji-cache.js",
      "check": true
    },
    {
      "src": "/api/name-origin-cache",
      "dest": "/api/name-origin-cache.js",
      "check": true
    },
    {
      "src": "/api/stats",
      "dest": "/api/stats.js",
      "check": true
    },
    {
      "src": "/api/premium-trial",
      "dest": "/api/premium-trial.js",
      "check": true
    },
    {
      "src": "/api/revenuecat-webhook",
      "dest": "/api/revenuecat-webhook.js",
      "check": true
    },
    {
      "src": "/api/backup-restore",
      "dest": "/api/backup-restore.js",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1",
      "check": true
    }
  ],
  "functions": {
    "api/gemini.js": {
      "maxDuration": 120
    },
    "api/kanji-cache.js": {
      "maxDuration": 120
    },
    "api/name-origin-cache.js": {
      "maxDuration": 120
    },
    "api/stats.js": {
      "maxDuration": 120
    },
    "api/premium-trial.js": {
      "maxDuration": 30
    },
    "api/revenuecat-webhook.js": {
      "maxDuration": 30
    },
    "api/backup-restore.js": {
      "maxDuration": 30
    }
  }
}
