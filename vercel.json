{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/gemini",
      "destination": "/api/gemini.js"
    },
    {
      "source": "/api/kanji-cache",
      "destination": "/api/kanji-cache.js"
    },
    {
      "source": "/api/stats",
      "destination": "/api/stats.js"
    },
    {
      "source": "/api/premium-trial",
      "destination": "/api/premium-trial.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ],
  "functions": {
    "api/gemini.js": {
      "maxDuration": 120
    },
    "api/kanji-cache.js": {
      "maxDuration": 120
    },
    "api/stats.js": {
      "maxDuration": 120
    },
    "api/premium-trial.js": {
      "maxDuration": 30
    }
  }
}
