rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRole(value) {
      return value == 'mama' || value == 'papa';
    }

    function isRoomMember(roomId) {
      return signedIn() && (
        get(/databases/$(database)/documents/rooms/$(roomId)).data.memberAUid == request.auth.uid ||
        get(/databases/$(database)/documents/rooms/$(roomId)).data.memberBUid == request.auth.uid
      );
    }

    function isValidBackupRoom(roomCode) {
      return roomCode == null
        || (roomCode is string && roomCode.size() == 0)
        || (roomCode is string && roomCode.size() > 0 && isRoomMember(roomCode));
    }

    function isPublicStatsCollection(collectionId) {
      return collectionId == 'statistics'
        || collectionId == 'statistics_male'
        || collectionId == 'statistics_female'
        || collectionId == 'reading_statistics'
        || collectionId == 'reading_statistics_male'
        || collectionId == 'reading_statistics_female'
        || collectionId == 'reading_like_statistics'
        || collectionId == 'reading_like_statistics_male'
        || collectionId == 'reading_like_statistics_female'
        || collectionId == 'reading_saved_statistics'
        || collectionId == 'reading_saved_statistics_male'
        || collectionId == 'reading_saved_statistics_female';
    }

    function canReadSharedBackup(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && (
          (
            resource.data.pairRoomCode is string
            && resource.data.pairRoomCode.size() > 0
            && isRoomMember(resource.data.pairRoomCode)
          ) ||
          (
            resource.data.roomCode is string
            && resource.data.roomCode.size() > 0
            && isRoomMember(resource.data.roomCode)
          )
        );
    }

    match /rooms/{roomId} {
      allow get: if signedIn();
      allow list: if false;

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'memberAUid', 'memberARole', 'memberASurname', 'memberASurnameReading',
          'memberBUid', 'memberBRole', 'memberBSurname', 'memberBSurnameReading',
          'pairedOnce', 'pairedAt', 'createdAt'
        ])
        && request.resource.data.memberAUid == request.auth.uid
        && isRole(request.resource.data.memberARole)
        && request.resource.data.memberBUid == null
        && request.resource.data.memberBRole == null
        && request.resource.data.pairedOnce == false
        && request.resource.data.pairedAt == null;

      allow update: if signedIn()
        && request.resource.data.keys().hasOnly([
          'memberAUid', 'memberARole', 'memberASurname', 'memberASurnameReading',
          'memberBUid', 'memberBRole', 'memberBSurname', 'memberBSurnameReading',
          'pairedOnce', 'pairedAt', 'createdAt'
        ])
        && (
          (
            resource.data.memberBUid == null
            && resource.data.pairedOnce != true
            && request.resource.data.memberAUid == resource.data.memberAUid
            && request.resource.data.memberARole == resource.data.memberARole
            && request.resource.data.memberASurname == resource.data.memberASurname
            && request.resource.data.memberASurnameReading == resource.data.memberASurnameReading
            && request.resource.data.memberBUid == request.auth.uid
            && isRole(request.resource.data.memberBRole)
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.pairedOnce == true
            && request.resource.data.pairedAt is timestamp
          ) ||
          (
            resource.data.memberAUid == request.auth.uid
            && request.resource.data.memberAUid == null
            && request.resource.data.memberARole == null
            && request.resource.data.memberASurname == null
            && request.resource.data.memberASurnameReading == null
            && request.resource.data.memberBUid == resource.data.memberBUid
            && request.resource.data.memberBRole == resource.data.memberBRole
            && request.resource.data.memberBSurname == resource.data.memberBSurname
            && request.resource.data.memberBSurnameReading == resource.data.memberBSurnameReading
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.pairedOnce == resource.data.pairedOnce
            && request.resource.data.pairedAt == resource.data.pairedAt
          ) ||
          (
            resource.data.memberBUid == request.auth.uid
            && request.resource.data.memberBUid == null
            && request.resource.data.memberBRole == null
            && request.resource.data.memberBSurname == null
            && request.resource.data.memberBSurnameReading == null
            && request.resource.data.memberAUid == resource.data.memberAUid
            && request.resource.data.memberARole == resource.data.memberARole
            && request.resource.data.memberASurname == resource.data.memberASurname
            && request.resource.data.memberASurnameReading == resource.data.memberASurnameReading
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.pairedOnce == resource.data.pairedOnce
            && request.resource.data.pairedAt == resource.data.pairedAt
          ) ||
          (
            resource.data.memberAUid == request.auth.uid
            && request.resource.data.memberAUid == resource.data.memberAUid
            && request.resource.data.memberARole == resource.data.memberARole
            && request.resource.data.memberBUid == resource.data.memberBUid
            && request.resource.data.memberBRole == resource.data.memberBRole
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'memberASurname', 'memberASurnameReading'
            ])
          ) ||
          (
            resource.data.memberBUid == request.auth.uid
            && request.resource.data.memberAUid == resource.data.memberAUid
            && request.resource.data.memberARole == resource.data.memberARole
            && request.resource.data.memberBUid == resource.data.memberBUid
            && request.resource.data.memberBRole == resource.data.memberBRole
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'memberBSurname', 'memberBSurnameReading'
            ])
          ) ||
          (
            (resource.data.memberAUid == request.auth.uid || resource.data.memberBUid == request.auth.uid)
            && resource.data.memberAUid != null
            && resource.data.memberBUid != null
            && resource.data.pairedOnce != true
            && request.resource.data.memberAUid == resource.data.memberAUid
            && request.resource.data.memberARole == resource.data.memberARole
            && request.resource.data.memberASurname == resource.data.memberASurname
            && request.resource.data.memberASurnameReading == resource.data.memberASurnameReading
            && request.resource.data.memberBUid == resource.data.memberBUid
            && request.resource.data.memberBRole == resource.data.memberBRole
            && request.resource.data.memberBSurname == resource.data.memberBSurname
            && request.resource.data.memberBSurnameReading == resource.data.memberBSurnameReading
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.pairedOnce == true
            && request.resource.data.pairedAt is timestamp
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'pairedOnce', 'pairedAt'
            ])
          )
        );

      allow delete: if false;
    }

    match /rooms/{roomId}/data/{userId} {
      allow read: if isRoomMember(roomId);
      allow create, update, delete: if isRoomMember(roomId) && isSelf(userId);
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || canReadSharedBackup(userId);

      allow create: if isSelf(userId)
        && request.resource.data.keys().hasOnly([
          'appAccountToken', 'premiumPlatform', 'appStoreBundleId', 'premiumLinkedAt',
          'revenueCatAppUserId', 'revenueCatPlatform', 'revenueCatLinkedAt', 'updatedAt',
          'meimayBackup', 'backup', 'meimayBackupFingerprint', 'meimayBackupUpdatedAt', 'pairRoomCode', 'roomCode', 'hiddenReadings', 'liked',
          'savedNames', 'readingStock', 'encounteredReadings', 'likedRemoved'
        ])
        && isValidBackupRoom(request.resource.data.pairRoomCode);

      allow update: if isSelf(userId)
        && request.resource.data.keys().hasOnly([
          'appAccountToken', 'premiumPlatform', 'appStoreBundleId', 'premiumLinkedAt',
          'revenueCatAppUserId', 'revenueCatPlatform', 'revenueCatLinkedAt', 'updatedAt',
          'meimayBackup', 'backup', 'meimayBackupFingerprint', 'meimayBackupUpdatedAt', 'pairRoomCode', 'roomCode', 'hiddenReadings', 'liked',
          'savedNames', 'readingStock', 'encounteredReadings', 'likedRemoved',
          'isPremium', 'premiumSource', 'subscriptionStatus', 'premiumStatus', 'latestNotificationType', 'latestNotificationUUID',
          'appStoreLastNotificationType', 'appStoreLastSubtype', 'appStoreEnvironment', 'appStoreProductId',
          'premiumProductId', 'appStoreOriginalTransactionId', 'originalTransactionId', 'appStoreTransactionId',
          'appStoreExpiresAt', 'premiumExpiresAt', 'appStoreLastEventAt', 'appStoreLastEventAtMs',
          'appStoreLastVerifiedAt', 'lastVerifiedAt', 'appStoreUpdatedAt',
          'revenueCatLastEventType', 'revenueCatLastEventId', 'revenueCatStore', 'revenueCatEnvironment',
          'revenueCatProductId', 'revenueCatTransactionId', 'revenueCatOriginalTransactionId',
          'revenueCatPresentedOfferingId', 'revenueCatPeriodType', 'revenueCatPurchasedAt',
          'revenueCatExpiresAt', 'revenueCatLastEventAt', 'revenueCatLastEventAtMs',
          'revenueCatUpdatedAt',
          'trialStatus', 'trialStartedAt', 'trialEndsAt', 'trialConsumedAt', 'trialSource',
          'trialRoomCode', 'trialConsumedByRoom'
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'appAccountToken', 'premiumPlatform', 'appStoreBundleId', 'premiumLinkedAt',
          'revenueCatAppUserId', 'revenueCatPlatform', 'revenueCatLinkedAt', 'updatedAt',
          'meimayBackup', 'backup', 'meimayBackupFingerprint', 'meimayBackupUpdatedAt', 'pairRoomCode', 'roomCode', 'hiddenReadings', 'liked',
          'savedNames', 'readingStock', 'encounteredReadings', 'likedRemoved'
        ])
        && isValidBackupRoom(request.resource.data.pairRoomCode);

      allow delete: if false;
    }

    match /statistics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /reading_statistics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /{collectionId}/{docId} {
      allow read: if isPublicStatsCollection(collectionId);
      allow write: if false;
    }

    match /kanji_ai_explanations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /kanji_ai_reading_explanations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /billingPending/{docId} {
      allow read, write: if false;
    }

    match /appStoreNotifications/{docId} {
      allow read, write: if false;
    }

    match /revenueCatEvents/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
